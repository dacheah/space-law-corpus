{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://space-law-corpus/schema/derived-metadata.schema.json",
  "title": "Derived artifacts metadata (list)",
  "description": "A list of derived-artifact provenance records for one authoritative document version. See docs/design/06-two-layer-separation.md. Phase E refinement (2026-07-02): the file holds a LIST so multiple artifacts coexist per version, and generation_method allows 'rule_based' for deterministic (non-model) passes. Every record must trace to a specific authoritative version.",
  "type": "array",
  "minItems": 1,
  "items": { "$ref": "#/$defs/artifact" },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derived_id", "derived_type", "artifact_file", "source_corpus_id",
        "source_version_id", "source_text_sha256", "generation_method",
        "generator", "generation_date", "review_status", "license", "disclaimer"
      ],
      "properties": {
        "derived_id": { "type": "string" },
        "derived_type": { "type": "string", "enum": ["translation", "summary", "structure_extraction", "concept_tags"] },
        "artifact_file": { "type": "string" },
        "source_corpus_id": { "type": "string" },
        "source_version_id": { "type": "string" },
        "source_text_sha256": { "type": "string", "pattern": "^sha256:" },
        "generation_method": { "type": "string", "enum": ["model", "human", "hybrid", "rule_based"] },
        "generator": { "type": "string" },
        "generation_date": { "type": "string", "format": "date" },
        "model_params": { "type": "object" },
        "review_status": { "type": "string", "enum": ["unreviewed", "machine_only", "human_reviewed"] },
        "reviewed_by": { "type": ["string", "null"] },
        "license": { "type": "string", "const": "CC-BY-4.0" },
        "confidence_note": { "type": "string" },
        "disclaimer": { "type": "string", "minLength": 1 }
      }
    }
  }
}
